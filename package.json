{
  "name": "followjs",
  "version": "2.1.1",
  "productName": "FollowJS",
  "description": "ArtNet FollowSpot control",
  "main": "index.js",
  "author": "Lennart Clausing",
  "license": "MIT",
  "scripts": {
    "test": "electron .",
    "start": "electron .",
    "icons": "node scripts/generate-icons.js",
    "build:win": "electron-builder --win nsis portable --x64",
    "build:mac": "electron-builder --mac dmg zip --arm64",
    "build": "npm run icons && npm run build:win && npm run build:mac",
    "dist": "npm run build"
  },
  "private": true,
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.lclausing.followjs",
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "extraResources": "config"
  },
  "dependencies": {
    "jspack": "^0.0.4",
    "node-check-update": "^0.0.0",
    "npm-check-updates": "^22.2.3",
    "requirejs": "^2.3.8"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "electron-winstaller@5.4.0": true
  }
}
