{
  "name": "followjs",
  "version": "2.0.0",
  "productName": "FollowJS",
  "description": "ArtNet FollowSpot control",
  "main": "index.js",
  "author": "Lennart Clausing",
  "license": "MIT",
  "scripts": {
    "test": "electron .",
    "start": "electron .",
    "pack": "electron-builder -mw --x64",
    "dist": "electron-builder"
  },
  "private": true,
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.lclausing.followjs",
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "extraResources": "config"
  },
  "dependencies": {
    "jspack": "^0.0.4",
    "node-check-update": "^0.0.0",
    "npm-check-updates": "^22.2.3",
    "requirejs": "^2.3.8"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "electron-winstaller@5.4.0": true
  }
}
